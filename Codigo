    }
}

/* ========================== LOOP PRINCIPAL ========================== */
/* Retorna: 0=game over, 1=avancar fase, -1=menu/vitoria */
static int game_loop(void) {
    while (1) {
        update_monsters();

        if (player_dead()) {
            player.lives--;
            if (player.lives <= 0) {
                show_game_over();
                return 0;
            }
            /* reinicia fase mantendo vidas e arma */
            int ph  = phase;
            int wep = player.weapon;
            int lv  = player.lives;
            init_phase(ph);
            player.weapon = wep;
            player.lives  = lv;
            continue;
        }

        draw_map();

        char key = read_key();
        if (key == 'q') return -1;

        int nr = player.row, nc = player.col;
        int moved = 0;

        if      (key == 'w') { player.dir = DIR_UP;    nr--; moved = 1; }
        else if (key == 's') { player.dir = DIR_DOWN;  nr++; moved = 1; }
        else if (key == 'a') { player.dir = DIR_LEFT;  nc--; moved = 1; }
        else if (key == 'd') { player.dir = DIR_RIGHT; nc++; moved = 1; }
        else if (key == 'i') { do_interact(); }
        else if (key == 'o') { do_attack(); }

        if (moved && !is_blocked(nr, nc)) {
            player.row = nr;
            player.col = nc;
            char cell = cur_map.grid[player.row][player.col];

            if (cell == SYM_STAIR) {
                /* Vila: so avanca se escolheu arma */
                if (phase == PHASE_VILA && player.weapon == WPN_NONE) {
                    /* nao avanca sem arma */
                } else if (phase == PHASE_F3 && cur_map.boss_dead) {
                    show_victory();
                    return -1;
                } else if (phase != PHASE_F3) {
                    return 1;
                }
            }
        }
    }
}

/* ========================== MAIN ========================== */
int main(void) {
    srand((unsigned int)time(NULL));

#ifndef _WIN32
    tcgetattr(STDIN_FILENO, &orig_termios);
    atexit(term_restore);
#endif

    while (1) {
        int choice = show_menu();
        if (choice == 0) break;

        player.lives  = 3;
        player.weapon = WPN_NONE;
        player.keys_count = 0;

        init_phase(PHASE_VILA);
        term_raw();

        int cur_phase = PHASE_VILA;

        while (1) {
            int result = game_loop();
            if (result <= 0) break;  /* 0=game over, -1=menu/vitoria */
            /* Avanca de fase */
            cur_phase++;
            if (cur_phase > PHASE_F3) break;
            int wep  = player.weapon;
            int lv   = player.lives;
            init_phase(cur_phase);
            player.weapon = wep;
            player.lives  = lv;
        }

        term_restore();
    }

    clear_screen();
    printf("Ate a proxima, aventureiro!\n");
    return 0;
}
