/* ========================== STRUCTS ========================== */
typedef struct {
    int row, col;
    int dir;
    int lives;
    int weapon;
    int keys_count;
} Player;

typedef struct {
    int row, col;
    int type;       /* 1=X aleat, 2=Y perseg, 3=Z boss */
    int alive;
    int hp;
    int boss_phase;
    int boss_timer;
    int summon_cd;
} Monster;

typedef struct {
    char    grid[MAX_ROWS][MAX_COLS];
    int     rows, cols;
    Monster monsters[MAX_MONSTERS];
    int     mon_count;
    int     keys_collected;
    int     total_keys;
    int     boss_dead;
    int     start_row, start_col;
} Map;

/* ========================== GLOBAIS ========================== */
static Player player;
static Map    cur_map;
static int    phase;

/* ========================== UTILITARIOS ========================== */
static void clear_screen(void) {
    system(CLEAR_CMD);
}

static void print_center(const char *text, int width) {
    int len = (int)strlen(text);
    int pad = (width - len) / 2;
    if (pad < 0) pad = 0;
    printf("%*s%s\n", pad, "", text);
}

static void press_any_key(void) {
    printf("\n  Pressione qualquer tecla para continuar...");
    fflush(stdout);
    term_restore();
    read_key();
    term_raw();
}

/* ========================== DESENHO ========================== */
static char player_char(int dir) {
    switch (dir) {
        case DIR_UP:    return '^';
        case DIR_DOWN:  return 'v';
        case DIR_LEFT:  return '<';
        case DIR_RIGHT: return '>';
    }
    return '>';
}

static void draw_map(void) {
    clear_screen();

    /* --- HUD --- */
    const char *wpn = "---";
    if (player.weapon == WPN_SWORD) wpn = "Espada";
    else if (player.weapon == WPN_BOW)   wpn = "Arco";
    else if (player.weapon == WPN_STAFF) wpn = "Cajado";

    const char *pname = "Vila";
    if (phase == PHASE_F1) pname = "Masmorra - Andar 1";
    else if (phase == PHASE_F2) pname = "Masmorra - Andar 2";
    else if (phase == PHASE_F3) pname = "Masmorra - Andar 3";

    printf("  [ %-20s ]  Vidas: ", pname);
    for (int i = 0; i < 3; i++) printf(i < player.lives ? "* " : ". ");
    printf(" Arma: %-10s Chaves: %d/%d\n",
           wpn, player.keys_count, cur_map.total_keys);

    /* borda superior */
    printf("  +");
    for (int c = 0; c < cur_map.cols; c++) printf("-");
    printf("+\n");

    for (int r = 0; r < cur_map.rows; r++) {
        printf("  |");
        for (int c = 0; c < cur_map.cols; c++) {
            if (r == player.row && c == player.col)
                putchar(player_char(player.dir));
            else
                putchar(cur_map.grid[r][c]);
        }
        printf("|\n");
    }

    /* borda inferior */
    printf("  +");
    for (int c = 0; c < cur_map.cols; c++) printf("-");
    printf("+\n");

    printf("  [wasd] Mover  [i] Interagir  [o] Atacar  [q] Menu\n");
    fflush(stdout);
}

/* ========================== MAPAS ========================== */
static void mon_add(Map *m, int row, int col, int type) {
    if (m->mon_count >= MAX_MONSTERS) return;
    Monster *mn  = &m->monsters[m->mon_count++];
    mn->row      = row;
    mn->col      = col;
    mn->type     = type;
    mn->alive    = 1;
    mn->hp = (type == 3) ? 3 : 1;
    mn->boss_phase = 1;
    mn->boss_timer = 0;
    mn->summon_cd  = 0;
    char sym = (type == 1) ? SYM_MON1 : (type == 2) ? SYM_MON2 : SYM_BOSS;
    m->grid[row][col] = sym;
}

static void map_load(Map *m, int rows, int cols,
                     const char *tmpl[], int nrows) {
    m->rows = rows;
    m->cols = cols;
    m->mon_count      = 0;
    m->keys_collected = 0;
    m->boss_dead      = 0;
    for (int r = 0; r < rows; r++) {
        int tlen = (r < nrows) ? (int)strlen(tmpl[r]) : 0;
        for (int c = 0; c < cols; c++) {
            char ch = (c < tlen) ? tmpl[r][c] : SYM_EMPTY;
            m->grid[r][c] = ch;
        }
    }
}

