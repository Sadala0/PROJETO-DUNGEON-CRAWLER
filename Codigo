static void init_phase(int ph) {
    phase = ph;
    switch (ph) {
        case PHASE_VILA: build_vila(&cur_map);   break;
        case PHASE_F1:   build_floor1(&cur_map); break;
        case PHASE_F2:   build_floor2(&cur_map); break;
        case PHASE_F3:   build_floor3(&cur_map); break;
    }
    player.row        = cur_map.start_row;
    player.col        = cur_map.start_col;
    player.dir        = DIR_RIGHT;
    player.keys_count = 0;
}

/* ========================== ATAQUE ========================== */
static int in_bounds(int r, int c) {
    return r >= 0 && r < cur_map.rows && c >= 0 && c < cur_map.cols;
}

static void attack_cell(int r, int c) {
    if (!in_bounds(r, c)) return;
    char cell = cur_map.grid[r][c];
    if (cell == SYM_BOX) {
        cur_map.grid[r][c] = SYM_EMPTY;
        return;
    }
    for (int i = 0; i < cur_map.mon_count; i++) {
        Monster *mn = &cur_map.monsters[i];
        if (!mn->alive || mn->row != r || mn->col != c) continue;
        mn->hp--;
        if (mn->hp <= 0) {
            mn->alive = 0;
            cur_map.grid[r][c] = SYM_EMPTY;
            if (mn->type == 3) {
                cur_map.boss_dead = 1;
                /* Desbloqueia escada */
                cur_map.grid[22][20] = SYM_STAIR;
            }
        }
        return;
    }
}

static void do_attack(void) {
    int pr = player.row, pc = player.col, dir = player.dir;

    if (player.weapon == WPN_STAFF) {
        int dr, dc;
        for (dr = -1; dr <= 1; dr++)
            for (dc = -1; dc <= 1; dc++)
                if (dr != 0 || dc != 0)
                    attack_cell(pr + dr, pc + dc);
        return;
    }

    if (player.weapon == WPN_BOW) {
        int dr = 0, dc = 0;
        if      (dir == DIR_UP)    dr = -1;
        else if (dir == DIR_DOWN)  dr =  1;
        else if (dir == DIR_LEFT)  dc = -1;
        else                       dc =  1;
        for (int s = 1; s <= 4; s++) {
            int nr = pr + dr * s, nc = pc + dc * s;
            if (!in_bounds(nr, nc)) break;
            attack_cell(nr, nc);
            char ch = cur_map.grid[nr][nc];
            if (ch == SYM_WALL) break;
        }
        return;
    }

    /* Espada: 3x2 a frente */
    int cells[6][2];
    int n = 0;
    if (dir == DIR_UP) {
        cells[n][0]=-1; cells[n++][1]=-1;
        cells[n][0]=-1; cells[n++][1]= 0;
        cells[n][0]=-1; cells[n++][1]= 1;
        cells[n][0]=-2; cells[n++][1]=-1;
        cells[n][0]=-2; cells[n++][1]= 0;
        cells[n][0]=-2; cells[n++][1]= 1;
    } else if (dir == DIR_DOWN) {
        cells[n][0]= 1; cells[n++][1]=-1;
        cells[n][0]= 1; cells[n++][1]= 0;
        cells[n][0]= 1; cells[n++][1]= 1;
        cells[n][0]= 2; cells[n++][1]=-1;
        cells[n][0]= 2; cells[n++][1]= 0;
        cells[n][0]= 2; cells[n++][1]= 1;
    } else if (dir == DIR_LEFT) {
        cells[n][0]=-1; cells[n++][1]=-1;
        cells[n][0]= 0; cells[n++][1]=-1;
        cells[n][0]= 1; cells[n++][1]=-1;
        cells[n][0]=-1; cells[n++][1]=-2;
        cells[n][0]= 0; cells[n++][1]=-2;
        cells[n][0]= 1; cells[n++][1]=-2;
    } else {
        cells[n][0]=-1; cells[n++][1]= 1;
        cells[n][0]= 0; cells[n++][1]= 1;
        cells[n][0]= 1; cells[n++][1]= 1;
        cells[n][0]=-1; cells[n++][1]= 2;
        cells[n][0]= 0; cells[n++][1]= 2;
        cells[n][0]= 1; cells[n++][1]= 2;
    }
    for (int i = 0; i < n; i++)
        attack_cell(pr + cells[i][0], pc + cells[i][1]);
}

/* ========================== INTERACAO ========================== */
static void do_interact(void) {
    int fr = player.row, fc = player.col;
    if      (player.dir == DIR_UP)    fr--;
    else if (player.dir == DIR_DOWN)  fr++;
    else if (player.dir == DIR_LEFT)  fc--;
    else                              fc++;

    if (!in_bounds(fr, fc)) return;
    char cell = cur_map.grid[fr][fc];

    if (cell == SYM_KEY) {
        cur_map.grid[fr][fc] = SYM_EMPTY;
        player.keys_count++;
        cur_map.keys_collected++;
        return;
    }
    if (cell == SYM_DOOR_C && player.keys_count > 0) {
        cur_map.grid[fr][fc] = SYM_DOOR_O;
        player.keys_count--;
        return;
    }
    if (cell == SYM_BUTTON) {
        cur_map.grid[fr][fc] = SYM_EMPTY;
        /* Efeito: abre passagem no andar 2 */
       if (phase == PHASE_F2) {
    for (int c = 1; c <= 5; c++) {
        cur_map.grid[12][c] = SYM_EMPTY;
    }
}
        /* Efeito andar 3: invoca monstro */
        if (phase == PHASE_F3)
            mon_add(&cur_map, player.row + 2, player.col + 2, 1);
        return;
    }
    /* NPC na Vila: escolha de arma */
    if (cell == SYM_NPC && phase == PHASE_VILA) {
        term_restore();
        clear_screen();
        printf("\n\n");
        print_center("=== Ferreiro Aldric ===", 50);
        printf("\n");
        printf("  \"Aventureiro! A masmorra e perigosa.\n");
        printf("   Escolha sua arma com sabedoria!\"\n\n");
        printf("  1. Espada  - Ataca regiao 3x2 a frente\n");
        printf("  2. Arco    - Ataca 4 celulas em linha reta\n");
        printf("  3. Cajado  - Ataca todas 8 celulas adjacentes\n\n");
        printf("  Escolha [1/2/3]: ");
        fflush(stdout);
        term_raw();
        char ch;
        do { ch = read_key(); } while (ch != '1' && ch != '2' && ch != '3');
        if (ch == '1') player.weapon = WPN_SWORD;
        else if (ch == '2') player.weapon = WPN_BOW;
        else player.weapon = WPN_STAFF;
        return;
    }
}

/* ========================== IA DOS MONSTROS ========================== */
static int cell_walkable(int r, int c) {
    if (!in_bounds(r, c)) return 0;
    char ch = cur_map.grid[r][c];
    return ch == SYM_EMPTY || ch == SYM_DOOR_O;
}

static int mon_at(int r, int c, Monster *skip) {
    int i;
    for (i = 0; i < cur_map.mon_count; i++) {
        Monster *m = &cur_map.monsters[i];
        if (!m->alive || m == skip) continue;
        if (m->row == r && m->col == c) return 1;
    }
    return 0;
}

static void mon_move(Monster *mn, int nr, int nc, char sym) {
    if (!in_bounds(nr, nc)) return;
    if (!cell_walkable(nr, nc)) return;
    if (mon_at(nr, nc, mn)) return;
    cur_map.grid[mn->row][mn->col] = SYM_EMPTY;
    mn->row = nr;
    mn->col = nc;
    cur_map.grid[nr][nc] = sym;
}

static void move_type1(Monster *mn) {
    int dr[] = {-1, 1, 0, 0};
    int dc[] = { 0, 0,-1, 1};
    int d = rand() % 4;
    int tries = 0;
    while (tries++ < 8) {
        int nr = mn->row + dr[d], nc = mn->col + dc[d];
        if (cell_walkable(nr, nc) && !mon_at(nr, nc, mn)) {
            mon_move(mn, nr, nc, SYM_MON1);
            return;
        }
        d = rand() % 4;
    }
}

static void move_type2(Monster *mn) {
    int dr = player.row - mn->row;
    int dc = player.col - mn->col;
    int nr = mn->row, nc = mn->col;
    if (abs(dr) >= abs(dc))
        nr += (dr > 0) ? 1 : -1;
    else
        nc += (dc > 0) ? 1 : -1;
    mon_move(mn, nr, nc, SYM_MON2);
}

/*
 * BOSS - "Senhor das Sombras"
 */
static void move_boss(Monster *mn) {
    int dr = player.row - mn->row;
    int dc = player.col - mn->col;

    int nr = mn->row;
    int nc = mn->col;

    if (abs(dr) >= abs(dc))
        nr += (dr > 0) ? 1 : -1;
    else
        nc += (dc > 0) ? 1 : -1;

    mon_move(mn, nr, nc, SYM_BOSS);
}

static void update_monsters(void) {
    int i;
    for (i = 0; i < cur_map.mon_count; i++) {
        Monster *mn = &cur_map.monsters[i];
        if (!mn->alive) continue;
        switch (mn->type) {
            case 1: move_type1(mn); break;
            case 2: move_type2(mn); break;
            case 3: move_boss(mn);  break;
        }
    }
}

/* ========================== VERIFICACOES ========================== */
static int is_blocked(int r, int c) {
    if (!in_bounds(r, c)) return 1;
    char ch = cur_map.grid[r][c];
    return ch == SYM_WALL || ch == SYM_BOX || ch == SYM_DOOR_C || ch == SYM_NPC;
}

static int player_dead(void) {
    if (cur_map.grid[player.row][player.col] == SYM_SPIKE) return 1;
    int i;
    for (i = 0; i < cur_map.mon_count; i++) {
        Monster *mn = &cur_map.monsters[i];
        if (mn->alive && mn->row == player.row && mn->col == player.col)
            return 1;
    }
    return 0;
}

